# Deck Shelves — local dev environment.
# Copy to .env and fill in your values:  cp .env.example .env
# .env is gitignored (this .example is the committed template — never put real
# secrets here).

# ── Steam Deck SSH connection (used by pnpm deploy:deck / deck:* tasks) ────────
# Hostname or IP of the Deck to deploy to over SSH.
DECK_HOST=192.168.1.x
# SSH username on the Deck.
DECK_USER=deck
# Sudo password on the Deck — only used to restart plugin_loader / fix plugin-dir
# ownership on deploy. Leave BLANK and prefer passwordless sudo (NOPASSWD) or
# SSH keys; a plaintext password here is a security risk.
DECK_SUDO_PASS=

# ── CDP / CEF remote debugging (used by deckprobe + pnpm deck:* CDP tasks) ─────
# Host of the CEF DevTools endpoint. Defaults to DECK_HOST when unset.
#   • Remote Deck on your LAN → the Deck's IP (below).
#   • Local Steam on THIS machine → 127.0.0.1
DECK_CDP_HOST=192.168.1.x
# CEF remote-debugging port.
#   • Remote Deck (LAN)     → 8081
#   • Local Steam (same box)→ 8080  (Steam's CEF is localhost-only on 8080)
DECK_CDP_PORT=8081

# ── Local Decky install (used by pnpm deploy:local — running on THIS machine) ──
# Only needed if Decky Loader is installed outside the default ~/homebrew.
# Point either at the plugins dir directly, or at the homebrew root.
# DECKY_PLUGINS_DIR=/home/deck/homebrew/plugins
# DECKY_HOME=/home/deck/homebrew

# ── Local Millennium install (used by pnpm deploy:millennium) ────────────────
# Exact installed plugin directory. The deploy tool only updates its four
# allowlisted runtime files and preserves settings.json, settings.json.bak,
# and backups/. If unset, it tries to discover Steam and an existing install.
# MILLENNIUM_PLUGIN_DIR=C:\Program Files (x86)\Steam\millennium\plugins\deck-shelves
# Or set the parent directory and let the tool append deck-shelves.
# MILLENNIUM_PLUGINS_DIR=C:\Program Files (x86)\Steam\millennium\plugins
